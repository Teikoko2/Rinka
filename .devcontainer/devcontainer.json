{
    "name": "Rinka Env",
    "build": {
        "context": "..",
        "dockerfile": "dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "openai.chatgpt",
                "Anthropic.claude-code",
                "google.geminicodeassist"
            ]
        }
    },
    "features": {},
    "postCreateCommand": "pip3 install -r ${containerWorkspaceFolder}/requirements.txt",
    "remoteUser": "vscode"
}
